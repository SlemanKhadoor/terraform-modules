# Create the key pair
resource "tls_private_key" "key_name_1" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

# Create AWS key pair
resource "aws_key_pair" "key_name_1" {
  key_name   = "key_name"
  public_key = tls_private_key.key_name_1.public_key_openssh
}

# Save the private key to file
resource "local_file" "private_key" {
  content  = tls_private_key.key_name_1.private_key_pem
  filename = "/path/key_name_1.pem"
  file_permission = "0400"
}

# Output the key pair name (optional)
output "key_name_1" {
  value = aws_key_pair.key_name_1.key_name
}